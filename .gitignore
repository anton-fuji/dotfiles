# Ignore everything by default. This keeps generated state, caches, and secrets
# out of the dotfiles repo unless they are explicitly allowlisted below.
*

!.gitignore
!flake.nix
!flake.lock
!starship.toml

!btop/
!btop/btop.conf

!eza/
!eza/theme.yml

!fastfetch/
!fastfetch/**

!fish/
!fish/**

!gh-dash/
!gh-dash/config.yml

!htop/
!htop/htoprc

!hunk/
!hunk/config.toml

!nix/
!nix/**

!nvim/
!nvim/**

!sketchybar/
!sketchybar/**
sketchybar/noice.log
sketchybar/helpers/event_providers/**/bin/

!wezterm/
!wezterm/**

!yazi/
!yazi/**

!zed/
!zed/settings.json
!zed/keymap.json

!zellij/
!zellij/config.kdl
!zellij/layouts/
!zellij/layouts/**

.DS_Store
**/.DS_Store
*.bak
*.log
result
